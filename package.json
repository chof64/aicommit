{
  "name": "@chof64/aicommit",
  "version": "0.2.1",
  "description": "AI-powered commit message generator using opencode.ai zen",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chof64/aicommit.git"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aicommit": "./dist/aicommit.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p test/tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "format": "biome format --write",
    "check": "biome check --write",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^25.9.3",
    "release-it": "^20.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
